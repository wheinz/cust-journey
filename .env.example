# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# Caddy — set to your domain for auto-HTTPS, or ":80" for plain HTTP (IP-only)
DOMAIN=localhost

# Database — leave empty for local dev (defaults to cust_journey/db.sqlite3).
# In Docker set to /app/data/db.sqlite3 so the db_data volume picks it up.
DB_PATH=
